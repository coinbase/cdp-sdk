{
  "name": "@coinbase/x402-next",
  "version": "0.0.1",
  "description": "CDP-opinionated Next.js integration for x402",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lint:check": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "dependencies": {
    "@coinbase/x402": "workspace:*",
    "@x402/core": "~2.11.0",
    "@x402/evm": "~2.11.0",
    "@x402/next": "~2.11.0",
    "@x402/svm": "~2.11.0"
  },
  "peerDependencies": {
    "next": ">=16.1.6 <17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "next": "16.2.6",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
