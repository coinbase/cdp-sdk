# CDP credentials — required for cdp-eoa and cdp-smart integration tests.
# Obtain from https://portal.cdp.coinbase.com/ under API Keys.
# Without these set, CDP-backed integration tests are skipped automatically.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Skip the client-side pre-flight balance check before each payment (default: false)
# CDP_DISABLE_PREFLIGHT_BALANCE_CHECK=true

# Override public JSON-RPC endpoints for on-chain balance lookups and payment signing.
# JSON object mapping CAIP-2 network IDs to RPC URLs — only supply networks to override.
# CDP_RPC_URLS={"eip155:8453":"https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"}
