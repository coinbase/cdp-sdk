# CDP credentials — required for all e2e tests.
# Obtain from https://portal.cdp.coinbase.com/ under API Keys.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Raw EVM private key for the Go and Python e2e tests (payer wallet).
# The wallet must hold USDC on Base Sepolia.
PAYER_PRIVATE_KEY=

# Receiver address for Go/Python tests (must differ from payer to avoid self-payment rejection).
RECEIVER_ADDRESS=

# Required for cdp-scw.e2e.test.ts.
# Defaults to "x402-e2e-scw-owner" if not set.
# CDP_OWNER_ACCOUNT_NAME=x402-e2e-scw-owner

# Optional: overrides the default account name "x402-e2e-test".
# CDP_ACCOUNT_NAME=x402-e2e-test

# Note: The e2e tests make real USDC payments on Base Sepolia.
#
# The payer wallet (CDP_ACCOUNT_NAME, defaults to "x402-e2e-test") must hold
# USDC on Base Sepolia before running these tests. The payment goes to a
# separate receiver account ("<CDP_ACCOUNT_NAME>-receiver") so that the payer
# and payTo addresses are distinct — the CDP facilitator rejects self-payments.
#
# Fund the payer wallet via the Circle USDC testnet faucet:
#   https://faucet.circle.com/
