{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@coinbase/x402": ["../src/index.ts"],
      "@coinbase/x402/server": ["../src/core/server/index.ts"],
      "@coinbase/x402-express": ["../../x402-express/src/index.ts"],
      "@coinbase/x402-hono": ["../../x402-hono/src/index.ts"],
      "@coinbase/x402-next/server": ["../../x402-next/src/server.ts"],
      "@coinbase/x402-next": ["../../x402-next/src/index.ts"],
      "next/server": ["./mocks/next-server.ts"]
    }
  },
  "include": [
    "**/*.ts"
  ]
}
