{
  "name": "@coinbase/x402-hono",
  "version": "0.0.1",
  "description": "CDP-opinionated Hono integration for x402",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lint:check": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "dependencies": {
    "@coinbase/x402": "workspace:*",
    "@x402/core": "~2.11.0",
    "@x402/evm": "~2.11.0",
    "@x402/hono": "~2.11.0",
    "@x402/svm": "~2.11.0"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "hono": "^4.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
