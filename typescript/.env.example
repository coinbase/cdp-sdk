CDP_API_KEY_ID=your_api_key_id_here
CDP_API_KEY_SECRET=your_private_key_here
CDP_WALLET_SECRET=your_wallet_auth_key_here

# Address of the smart account used in e2e tests
CDP_E2E_SMART_ACCOUNT_ADDRESS=

# Recipient (payTo) for x402 signing e2e tests. Must differ from the payer.
# EVM defaults to a burn address if unset; Solana must be a devnet address that
# already has a USDC token account so the facilitator can verify the transfer.
CDP_E2E_X402_EVM_PAY_TO=
CDP_E2E_X402_SOLANA_PAY_TO=
