CDP_API_KEY_ID=your_api_key_id_here
CDP_API_KEY_SECRET=your_private_key_here
CDP_WALLET_SECRET=your_wallet_auth_key_here

# Optional (x402): RPC URLs used for payment signing on networks other than
# Base / Base Sepolia (those two resolve automatically via your CDP project's
# own node endpoint — no override needed). CDP doesn't host RPCs for other
# networks, so provide your own RPC provider's URL here. JSON object mapping
# CAIP-2 network IDs to URL strings.
# CDP_X402_RPC_URLS={"eip155:137":"https://your-rpc-provider.example.com/polygon"}

# Address of the smart account used in e2e tests
CDP_E2E_SMART_ACCOUNT_ADDRESS=

