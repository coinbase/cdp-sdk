CDP_API_KEY_ID=your-api-key-id
CDP_API_KEY_SECRET=your-api-key-secret
CDP_WALLET_SECRET=your-wallet-secret

# Wallet type: cdp-eoa | cdp-smart
CDP_WALLET_TYPE=cdp-eoa

# Optional named CDP account (defaults to x402-server-wallet-1)
# CDP_ACCOUNT_NAME=my-wallet

# Required only for cdp-smart
# CDP_OWNER_ACCOUNT_NAME=my-owner-wallet

# Skip the client-side pre-flight balance check before each payment (default: false)
# CDP_DISABLE_PREFLIGHT_BALANCE_CHECK=true

# Override public JSON-RPC endpoints — JSON object mapping CAIP-2 IDs to URLs
# CDP_RPC_URLS={"eip155:8453":"https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"}

RESOURCE_SERVER_URL=http://localhost:8402
ENDPOINT_PATH=/report
