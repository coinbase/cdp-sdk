# CDP credentials (cloud secrets are injected automatically in Cursor Desktop)
# CDP_API_KEY=organizations/.../apiKeys/...
# CDP_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----...
# CDP_WALLET_SECRET=...
# EOA_PRIVATE_KEY=...            # Smart account owner (0x prefix optional)
# BASE_RPC_ENDPOINT=https://api.developer.coinbase.com/rpc/v1/base/<token>

# Existing smart account (required — do not use get_or_create; no new wallets)
# SMART_ACCOUNT_ADDRESS=0x...
# AGENT_NAME=cdp-flash-liquidator   # fallback lookup by name when address unset

# Agent configuration
AGENT_NETWORK=base
# Multi-protocol scanning (comma-separated)
AGENT_PROTOCOLS=aave-v3,moonwell,compound-v3,morpho
# Near-liquidation watch threshold (oracle prep)
WATCH_HF_THRESHOLD=1.05
# Slippage buffer for profit estimation (bps)
SLIPPAGE_BPS=50
# eth_call simulation before execution
SIMULATE_BEFORE_EXECUTE=true
EXECUTE_ENABLED=false
MIN_PROFIT_USD=5.0
HEALTH_FACTOR_THRESHOLD=1.0
SCAN_INTERVAL_SECONDS=12
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8787

# Set after deploying FlashLiquidator.sol / MorphoFlashLiquidator.sol
# FLASH_LIQUIDATOR_ADDRESS=0x...
# MORPHO_FLASH_LIQUIDATOR_ADDRESS=0x...

# Live swap quotes for profit estimation (KyberSwap default; 1inch optional)
# SWAP_QUOTE_PROVIDER=auto
# ONEINCH_API_KEY=...

# Optional LLM augmentation
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
